{
    "name": "sportmonks/sqs-queue-monitor",
    "description": "Live SQS queue monitoring via Laravel Reverb",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/broadcasting": "^11.0 || ^12.0 || ^13.0",
        "illuminate/queue": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "pestphp/pest": "^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "QueueMonitor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "QueueMonitor\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "QueueMonitor\\QueueMonitorServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
